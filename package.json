{
  "name": "keeper-ai",
  "version": "0.1.0",
  "description": "Multi-agent system for day-2 operations of watched services",
  "private": true,
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "dev:dashboard": "cd dashboard && npm run dev",
    "dev:all": "concurrently --names api,ui --prefix-colors cyan,magenta \"npm run dev\" \"npm run dev:dashboard\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.2",
    "@fastify/cors": "^9.0.0",
    "@octokit/rest": "^21.0.0",
    "better-sqlite3": "^12.11.1",
    "fastify": "^4.26.0",
    "js-yaml": "^4.1.0",
    "node-cron": "^3.0.3",
    "pino": "^8.19.0",
    "pino-pretty": "^11.0.0",
    "dotenv": "^16.4.0",
    "zod": "^3.22.0"
  },
  "engines": {
    "node": "22.x"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/js-yaml": "^4.0.0",
    "@types/node": "^22.0.0",
    "@types/node-cron": "^3.0.0",
    "concurrently": "^9.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.4.0"
  }
}
